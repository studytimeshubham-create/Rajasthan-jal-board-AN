rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Consumers: read allowed for auth users (meter readers)
    match /consumers/{cin_no} {
      allow read: if isAuth();
      allow write: if false; // Admin SDK only
    }

    // Billing cycles: read allowed for auth users
    match /billing_cycles/{cycle_id} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Readings:
    // Read: allowed for auth users (meter readers can view histories/logs)
    // Create: reader can only submit for themselves
    // Update: reader can only update their own readings, and only before the edit window expires
    match /readings/{reading_id} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.reader_uid == request.auth.uid;
      allow update: if isAuth() 
                    && resource.data.reader_uid == request.auth.uid 
                    && request.resource.data.reader_uid == request.auth.uid
                    && resource.data.edit_window_expiry > request.time;
      allow delete: if false;
    }

    // Correction queries: reader can create and read their own queries
    match /correction_queries/{query_id} {
      allow read: if isAuth() && (resource == null || resource.data.reader_uid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.reader_uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Meter readers: each reader can only read their own document
    match /meter_readers/{uid} {
      allow read: if isAuth() && uid == request.auth.uid;
      allow write: if false;
    }

    // Charges config: read allowed for auth users
    match /charges_config/{config_id} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Blocks access to payments, adjustments, logs, replacement logs, and history snapshots
    match /payments/{payment_id} { allow read, write: if false; }
    match /custom_adjustments/{adj_id} { allow read, write: if false; }
    match /audit_log/{log_id} { allow read, write: if false; }
    match /meter_replacement_log/{log_id} { allow read, write: if false; }
    match /charges_config_history/{entry_id} { allow read, write: if false; }
  }
}
